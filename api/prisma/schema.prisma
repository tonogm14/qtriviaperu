// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Global order sequence — one row per purchase, auto-increments across all order types
model OrderSeq {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
}

model LifeOrder {
  id          String   @id @default(cuid())
  orderNumber Int?     @unique  // from OrderSeq
  userId      String
  packId      String
  packLabel   String
  lives       Int
  quantity    Int
  price       Float
  method      String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  username      String         @unique
  name          String
  password      String
  phone         String?
  avatarUrl     String?
  balance       Float          @default(0)
  lives         Int            @default(1)
  pushToken     String?
  isVip         Boolean        @default(false)
  role          Role           @default(USER)
  permissions   String[]       @default([])
  isActive      Boolean        @default(true)
  isArchived    Boolean        @default(false)
  isFlagged     Boolean        @default(false)
  flagReason    String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  entries        GameEntry[]
  withdrawals    Withdrawal[]
  notifications  Notification[]
  activityLogs   ActivityLog[]
  orders         Order[]
  lifeOrders     LifeOrder[]
  balanceLedger  BalanceLedger[]
  devices        UserDevice[]
}

model Game {
  id              String         @id @default(cuid())
  title           String
  type            GameType       @default(SPECIAL)
  isRecurring     Boolean        @default(false)
  recurringTime   String?        // "HH:MM" in Lima time, only for DAILY recurring games
  recurringMode   String         @default("DAILY") // DAILY | CONTINUOUS
  requiresCode    Boolean        @default(false)   // users must enter an invite code to join
  scheduledAt     DateTime
  status          GameStatus     @default(PENDING)
  prize           Float
  entryFee        Float          @default(0)
  maxQuestions    Int            @default(12)
  timePerQuestion Int            @default(10)
  host            String?
  category        String         @default("Mixta")
  currentPot      Float          @default(0)
  winnerId        String?
  winnerMode      String         @default("SINGLE")   // SINGLE | ALL_CORRECT | RANKED_SLOTS
  prizeSlots      Json?          // [{place:1,percent:50},{place:2,percent:30}] — RANKED_SLOTS only
  prizeMode       String         @default("FIXED")    // FIXED | POT | POT_PERCENT
  potPercent      Float          @default(100)        // % of pot → prize, only for POT_PERCENT
  sourceGameId    String?        // id of the recurring game this was spawned from
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  notified1h      Boolean        @default(false)
  notified5m      Boolean        @default(false)
  notifiedStart   Boolean        @default(false)
  streamUrl           String?
  muxStreamId         String?
  muxStreamKey        String?
  warmUpQuestionId    String?        // optional warmup question (no eliminations)
  prizeType           String         @default("MONETARY") // MONETARY | PHYSICAL
  prizeImage          String?        // URL to uploaded prize image
  prizeTitle          String?        // short prize title (e.g. "iPhone 16 Pro")
  prizeDescription    String?        // longer prize description
  entries             GameEntry[]
  questions           GameQuestion[]
  events              GameEvent[]
  inviteCodes         GameInviteCode[]
}

model GameEvent {
  id        String   @id @default(cuid())
  gameId    String
  type      String   // GAME_STARTED | PLAYER_ELIMINATED | GAME_ENDED | WINNER_DECLARED
  userId    String?  // null for game-level events
  data      Json?    // { qIdx?, score?, prize?, totalPlayers?, survivors?, totalPrize?, username? }
  createdAt DateTime @default(now())
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([createdAt])
}

model GameInviteCode {
  id        String    @id @default(cuid())
  gameId    String
  code      String    @unique
  label     String?   // optional: name/identifier of the intended recipient
  usedById  String?   // userId who redeemed it
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  game      Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
}

model Question {
  id           String         @id @default(cuid())
  text         String
  options      String[]
  correctIndex Int
  category     String         @default("General")
  difficulty   Difficulty     @default(MEDIUM)
  isArchived   Boolean        @default(false)
  createdAt    DateTime       @default(now())
  games        GameQuestion[]
}

model GameQuestion {
  id         String   @id @default(cuid())
  gameId     String
  questionId String
  order      Int
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id])
}

model GameEntry {
  id             String    @id @default(cuid())
  orderNumber    Int?      @unique  // from OrderSeq (only for VIP paid entries)
  userId         String
  gameId         String
  joinedAt       DateTime  @default(now())
  isAlive        Boolean   @default(true)
  eliminatedAtQ  Int?      // question index (0-based) when first eliminated; persists even after life use
  score          Int       @default(0)
  prize          Float?
  finishedAt     DateTime?
  answerLog      Json?     // [{qIdx, receivedAt}] — for anti-bot forensics
  user        User      @relation(fields: [userId], references: [id])
  game        Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
}

model UserDevice {
  id          String   @id @default(cuid())
  deviceId    String
  userId      String
  platform    String?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([deviceId, userId])
  @@index([deviceId])
}

model Withdrawal {
  id         String           @id @default(cuid())
  userId     String
  amount     Float
  method     String // yape | plin | bank
  accountRef String
  fee        Float            @default(0)
  netAmount  Float
  status     WithdrawalStatus @default(PENDING)
  code       String           @unique
  createdAt  DateTime         @default(now())
  user       User             @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // win | reminder | life | rank | bonus
  title     String
  body      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  type      String   // login | logout | page_view | tap | withdrawal_request | join_game | buy_lives | push_open | notification_view
  screen    String?
  action    String?
  meta      String?  // JSON string
  ip        String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([type])
}

model ScheduledNotification {
  id           String    @id @default(cuid())
  title        String
  body         String
  type         String    @default("general")
  target       String    @default("all") // "all" | "game" | "user"
  gameId       String?
  userEmail    String?
  scheduledFor DateTime
  sentAt       DateTime?
  createdAt    DateTime  @default(now())
}

enum Role {
  USER
  ADMIN
}

enum GameStatus {
  PENDING
  LOBBY
  LIVE
  FINISHED
  CANCELLED
  ARCHIVED
}

enum GameType {
  FREE
  VIP
  SPECIAL
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

model LifePack {
  id        String  @id
  lives     Int
  price     Float
  label     String
  tag       String?
  active    Boolean @default(true)
  sortOrder Int     @default(0)
}

model MerchItem {
  id        String   @id
  emoji     String
  name      String
  desc      String
  price     Float
  stock     Int      @default(-1)
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  gradient  String   @default("[\"#6366F1\",\"#4338CA\"]")
  orders    Order[]
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   Int?        @unique  // from OrderSeq; cart groups share the same number
  userId        String
  itemId        String
  quantity      Int
  total         Float
  method        String
  status        OrderStatus @default(PENDING)
  address       String?
  phone         String?
  recipientName String?
  dni           String?
  notes         String?
  cartRef       String?     // groups orders placed in the same cart checkout
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id])
  item          MerchItem   @relation(fields: [itemId], references: [id])
}

model BalanceLedger {
  id            String   @id @default(cuid())
  userId        String
  type          String   // PRIZE_WIN | ENTRY_FEE | WITHDRAWAL_REQUEST | WITHDRAWAL_REFUND | BONUS | ADJUSTMENT
  amount        Float    // positive = credit, negative = debit
  balanceAfter  Float    // user balance snapshot after this entry
  description   String
  referenceId   String?  // gameId, withdrawalId, etc.
  referenceType String?  // GAME | WITHDRAWAL | ADMIN
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}

model AppConfig {
  id               String   @id @default("main")
  currency         String   @default("PEN")
  defaultPrize     Float    @default(5000)
  defaultQuestions Int      @default(12)
  defaultTime      Int      @default(10)
  pushBefore       Int      @default(10)
  autoAdvance      Boolean  @default(false)
  chatModeration   Boolean  @default(true)
  minWithdraw      Float    @default(100)
  feeYape          Float    @default(0)
  feePlin          Float    @default(0)
  feeBCP           Float    @default(5)
  feeInterbank     Float    @default(5)
  termsAndConditions String @default("")
  privacyPolicy    String   @default("")
  autoCloseRegistration Boolean @default(true)
  updatedAt        DateTime @updatedAt
}

model BadWord {
  id        String   @id @default(cuid())
  word      String   @unique
  createdAt DateTime @default(now())
}
